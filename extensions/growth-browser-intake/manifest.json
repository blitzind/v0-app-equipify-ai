{
  "manifest_version": 3,
  "name": "Equipify Growth Intake",
  "version": "3.1.0",
  "description": "Smart capture for Equipify Growth Engine — LinkedIn status badges, side panel, visible metadata only.",
  "permissions": ["activeTab", "scripting", "storage", "sidePanel"],
  "host_permissions": ["https://app.equipify.ai/*", "http://localhost:3000/*", "https://*/*", "http://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Capture to Equipify Growth"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/in/*",
        "https://linkedin.com/in/*",
        "https://www.linkedin.com/company/*",
        "https://linkedin.com/company/*"
      ],
      "js": [
        "extension-storage.js",
        "extension-config.js",
        "linkedin-context.js",
        "linkedin-status-shared.js",
        "page-metadata.js",
        "linkedin-page-badge.js"
      ],
      "css": ["linkedin-page-badge.css"],
      "run_at": "document_idle"
    }
  ]
}

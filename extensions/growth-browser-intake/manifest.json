{
  "manifest_version": 3,
  "name": "Equipify Sales",
  "version": "4.3.24",
  "description": "Equipify Sales — LinkedIn prospecting sidebar with CRM context, capture, call prep, and queue tools. Visible metadata only.",
  "permissions": ["activeTab", "scripting", "storage", "sidePanel", "tabs"],
  "host_permissions": ["https://app.equipify.ai/*", "http://localhost:3000/*", "https://*/*", "http://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Equipify Sales",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "inpage-sidebar.html",
        "popup.css",
        "sales-workspace.css",
        "assets/equipify-lightning.png",
        "assets/equipify-sales-wordmark.png",
        "assets/icon-16.png",
        "assets/icon-32.png",
        "assets/icon-48.png",
        "assets/icon-128.png"
      ],
      "matches": ["https://www.linkedin.com/*", "https://linkedin.com/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/in/*",
        "https://linkedin.com/in/*",
        "https://m.linkedin.com/in/*",
        "https://m.linkedin.com/company/*",
        "https://www.linkedin.com/company/*",
        "https://linkedin.com/company/*"
      ],
      "js": [
        "extension-storage.js",
        "extension-config.js",
        "extension-brand.js",
        "extension-lookup-cache.js",
        "extension-contact-saved.js",
        "linkedin-context.js",
        "linkedin-status-shared.js",
        "linkedin-crm-shared.js",
        "page-metadata.js",
        "linkedin-company-people.js",
        "linkedin-inpage-sidebar.js",
        "linkedin-crm-overlay.js",
        "linkedin-floating-dock.js"
      ],
      "css": [
        "linkedin-inpage-sidebar.css",
        "linkedin-crm-overlay.css",
        "linkedin-floating-dock.css"
      ],
      "run_at": "document_idle"
    }
  ]
}

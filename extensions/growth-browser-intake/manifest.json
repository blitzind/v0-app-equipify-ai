{
  "manifest_version": 3,
  "name": "Equipify Sales",
  "version": "4.0.0",
  "description": "Equipify Sales — capture prospects, CRM context, call prep, prospect queue, and buying committee tools. Visible metadata only.",
  "permissions": ["activeTab", "scripting", "storage", "sidePanel"],
  "host_permissions": ["https://app.equipify.ai/*", "http://localhost:3000/*", "https://*/*", "http://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Equipify Sales"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/in/*",
        "https://linkedin.com/in/*",
        "https://www.linkedin.com/company/*",
        "https://linkedin.com/company/*"
      ],
      "js": [
        "extension-storage.js",
        "extension-config.js",
        "extension-lookup-cache.js",
        "linkedin-context.js",
        "linkedin-status-shared.js",
        "linkedin-crm-shared.js",
        "page-metadata.js",
        "linkedin-crm-overlay.js"
      ],
      "css": ["linkedin-crm-overlay.css"],
      "run_at": "document_idle"
    }
  ]
}

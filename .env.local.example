# Copy to .env.local and fill in values.

# Supabase (example — use your project values)
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxx
# Server-only: hosted Checkout + POST /api/stripe/webhook (writes organization_subscriptions). Never expose to the browser.
# SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxx

# Stripe — publishable key (client) and secrets (server). Webhook secret for POST /api/stripe/webhook (signature verification).
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxx
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxx
# BlitzPay / Stripe Connect — separate webhook signing secret for POST /api/blitzpay/webhook (account.updated).
# Do not reuse STRIPE_WEBHOOK_SECRET. See docs/BLITZPAY_PHASE_1.md
# STRIPE_BLITZPAY_WEBHOOK_SECRET=whsec_xxxxxxxxx
# Phase 2 — tenant invoice pay (global kill switch; default off). See docs/BLITZPAY_PHASE_2_ARCHITECTURE.md
# BLITZPAY_INVOICE_PAY_ENABLED=false
# Per-org enable: set blitzpay_org_settings.blitzpay_invoice_pay_enabled = true (service role / SQL) for the organization UUID.

# BlitzPay Phase 2AA — optional server-only pepper for hashing Stripe object references in DB (migration filename may still say phase_3a; see docs/STRIPE_PRODUCTION_READINESS.md).
# BLITZPAY_STRIPE_REF_PEPPER=
# Phase 3A — internal GL source fingerprint (server-only; optional in dev)
# BLITZPAY_GL_SOURCE_PEPPER=

# Optional: POST /api/organizations/…/invoices/…/blitzpay/prepare-pay rate buckets (uses ai_operation_rate_buckets). Defaults are conservative if unset.
# BLITZPAY_RATE_PREPARE_PER_ORG_PER_MIN=20
# BLITZPAY_RATE_PREPARE_PER_INVOICE_PER_MIN=8
# BLITZPAY_RATE_PREPARE_PER_USER_PER_MIN=10

# Temporary: sanitized server logs for POST …/blitzpay/enable and account-link (disable after debugging).
# BLITZPAY_ENABLE_DEBUG=true

# Optional: force live key checks without Vercel Production (sk_live_/pk_live_ required).
# See docs/STRIPE_PRODUCTION_READINESS.md
# STRIPE_LIVE_MODE=true

# Public app URL — used for Stripe redirects, invite links, signup welcome, AI Ops digest links.
# Prefer NEXT_PUBLIC_SITE_URL; see docs/EMAIL_INFRASTRUCTURE.md for fallbacks.
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# Server-only fallback (optional): APP_URL=https://staging.example.com

# Stripe Price IDs (Dashboard → Products → each Price).
# Required for checkout validation against real IDs and webhook inverse-mapping.
# Optional in dev if you use catalog placeholders only locally.

# STRIPE_PRICE_SOLO_MONTHLY=price_xxxxxxxxx
# STRIPE_PRICE_SOLO_ANNUAL=price_xxxxxxxxx

# STRIPE_PRICE_CORE_MONTHLY=price_xxxxxxxxx
# STRIPE_PRICE_CORE_ANNUAL=price_xxxxxxxxx

# STRIPE_PRICE_GROWTH_MONTHLY=price_xxxxxxxxx
# STRIPE_PRICE_GROWTH_ANNUAL=price_xxxxxxxxx

# STRIPE_PRICE_SCALE_MONTHLY=price_xxxxxxxxx
# STRIPE_PRICE_SCALE_ANNUAL=price_xxxxxxxxx

# OpenAI — used only on the server for AI-assisted certificate template import (PDF/images).
# Never commit real keys or expose this variable to the browser.
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx

# Optional model override (defaults to gpt-4o)
# OPENAI_IMPORT_MODEL=gpt-4o

# QuickBooks Online — Intuit Developer App (OAuth 2.0).
# Callback route:
# /api/integrations/quickbooks/callback
# Register the exact REDIRECT_URI in the Intuit app.

# QUICKBOOKS_CLIENT_ID=xxxxxxxxxxxxxxxx
# QUICKBOOKS_CLIENT_SECRET=xxxxxxxxxxxxxxxx
# QUICKBOOKS_REDIRECT_URI=http://localhost:3000/api/integrations/quickbooks/callback

# Optional: defaults to production accounting API. For Intuit sandbox companies, set the sandbox API host
# (URL must include "sandbox" so the app labels the deployment as sandbox in Settings).
# QUICKBOOKS_API_BASE_URL=https://sandbox-quickbooks.api.intuit.com

# HMAC secret for OAuth state (min 16 chars);
# required for /api/integrations/quickbooks/authorize
# INTEGRATION_OAUTH_STATE_SECRET=xxxxxxxxxxxxxxxx

# Resend — transactional email (server only). Used by invoice/quote emails, invites, onboarding welcome (Phase 54.4).
# If unset, provisioning still succeeds but emails are skipped with structured logs.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
# EMAIL_FROM_ADDRESS="Equipify <onboarding@yourdomain.com>"
# Optional reply-to for customer-facing messages (welcome, invoices, etc.)
# EMAIL_REPLY_TO=support@yourdomain.com

# Internal alert when a self-serve workspace finishes POST /api/onboarding/provision (default: mike@equipify.ai)
# EMAIL_SIGNUP_INTERNAL_NOTIFY=mike@equipify.ai

# See docs/SIGNUP_PROVISION_EMAILS.md and docs/EMAIL_INFRASTRUCTURE.md

# --- Future: Gmail / Google mailbox OAuth (not wired in app yet; Phase 55.5 is docs + honest UI only) ---
# Register a Google Cloud OAuth 2.0 Web client; never expose client secret to the browser.
# See docs/GMAIL_INTEGRATION.md for boundaries vs Resend.
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_GMAIL_REDIRECT_URI=http://localhost:3000/api/integrations/google-mail/callback
# Optional: GOOGLE_GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.send

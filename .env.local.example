# Copy to .env.local and fill in values.

# Supabase (example — use your project values)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: hosted Checkout + POST /api/stripe/webhook (writes organization_subscriptions). Never expose to the browser.
# SUPABASE_SERVICE_ROLE_KEY=

# Stripe — publishable key (client) and secrets (server). Webhook secret for POST /api/stripe/webhook (signature verification).
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# Optional: force live key checks without Vercel Production (sk_live_/pk_live_ required). See docs/STRIPE_PRODUCTION_READINESS.md
# STRIPE_LIVE_MODE=true

# Optional: absolute site URL for hosted Checkout success/cancel redirects when the request has no Origin header (e.g. some crawlers).
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe Price IDs (Dashboard → Products → each Price). Required for checkout validation against real IDs
# and for webhook inverse-mapping (plan + billing cycle). Optional in dev if you use catalog placeholders only locally.
# STRIPE_PRICE_SOLO_MONTHLY=
# STRIPE_PRICE_SOLO_ANNUAL=
# STRIPE_PRICE_CORE_MONTHLY=
# STRIPE_PRICE_CORE_ANNUAL=
# STRIPE_PRICE_GROWTH_MONTHLY=
# STRIPE_PRICE_GROWTH_ANNUAL=
# STRIPE_PRICE_SCALE_MONTHLY=
# STRIPE_PRICE_SCALE_ANNUAL=

# OpenAI — used only on the server for AI-assisted certificate template import (PDF/images).
# Never commit real keys or expose this variable to the browser.
OPENAI_API_KEY=

# Optional model override (defaults to gpt-4o)
# OPENAI_IMPORT_MODEL=gpt-4o

# QuickBooks Online — Intuit Developer App (OAuth 2.0). Callback route:
# /api/integrations/quickbooks/callback — register the exact REDIRECT_URI in the Intuit app.
# QUICKBOOKS_CLIENT_ID=
# QUICKBOOKS_CLIENT_SECRET=
# QUICKBOOKS_REDIRECT_URI=http://localhost:3000/api/integrations/quickbooks/callback
# HMAC secret for OAuth state (min 16 chars); required for /api/integrations/quickbooks/authorize
# INTEGRATION_OAUTH_STATE_SECRET=

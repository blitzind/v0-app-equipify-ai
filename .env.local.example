# GROWTH_WEBHOOK_SIMULATION=true
# Enable live DNS probes for deliverability intelligence (Phase 2):
# GROWTH_LIVE_DNS_VERIFICATION=true
# --- Bulk acquisition email verification (Native authoritative — GE-VERIFY-1A) ---
# GROWTH_NATIVE_VERIFICATION_AUTHORITATIVE=true
# GROWTH_NATIVE_VERIFICATION_DNS_ENABLED=true
# GROWTH_NATIVE_VERIFICATION_TTL_DAYS=90
# Certification: pnpm test:growth-native-verification-production-cert
# Legacy third-party verification is not used when authoritative mode is enabled.
# ZEROBOUNCE_API_KEY=  (deprecated — do not use)
# Optional alias: GROWTH_ZEROBOUNCE_API_KEY=
# Disable all verification: GROWTH_EMAIL_VERIFICATION_DISABLE=1
# Optional operational alerting (Phase 4 — platform admin only):
# GROWTH_OPS_SLACK_WEBHOOK_URL=
# GROWTH_OPS_ALERT_EMAIL=ops@your-domain.com
# Production REQUIRED for live outbound credentials (never use dev fallback in prod):
# GROWTH_PROVIDER_CREDENTIALS_PEPPER=
# Production REQUIRED for Growth crons:
# CRON_SECRET=
# Outbound send plane (Phase 6.30D default: standalone / native Gmail transport):
# GROWTH_OUTBOUND_MODE=standalone
# Rollback adapter/Lemlist execution only with BOTH:
# GROWTH_OUTBOUND_MODE=adapter
# GROWTH_ALLOW_ADAPTER_OUTBOUND=true
# Then re-add growth-outreach-execute to vercel.json and redeploy.
# Standalone: growth-sequence-scheduler cron (every 10 min) auto-plans due steps into sequence_execution_jobs.
# Bulk enroll up to 100 leads via POST /api/platform/growth/sequences/enroll/bulk (CRM lead list UI).
# Standalone solo operator — one click approves AI draft + execution job (platform admin only):
# GROWTH_OUTBOUND_SOLO_AUTO_APPROVE=true

# --- Marketing analytics (GA4 + Google Ads on app.equipify.ai) ---
# See docs/ANALYTICS_MARKETING_APP.md
# Defaults match www.equipify.ai when unset (see lib/analytics/marketing-analytics-config.ts).
# NEXT_PUBLIC_GA4_ID=G-YZMS47H63H
# NEXT_PUBLIC_GOOGLE_ADS_ID=AW-18160904774
# Full Google Ads "Free Trial Signup" conversion send_to (default when unset):
# NEXT_PUBLIC_GOOGLE_ADS_SIGNUP_SEND_TO=AW-18160904774/0J7wCMeXtqwcEMbU5dND
# Set to off to disable Ads conversion hits while keeping GA4 events:
# NEXT_PUBLIC_GOOGLE_ADS_SIGNUP_SEND_TO=off
# Optional overrides (defaults suit production *.equipify.ai):
# NEXT_PUBLIC_ANALYTICS_COOKIE_DOMAIN=.equipify.ai
# NEXT_PUBLIC_ANALYTICS_LINKER_DOMAINS=www.equipify.ai,app.equipify.ai,equipify.ai
# Dev-only: console logging for gtag init, page_view, conversions
# NEXT_PUBLIC_ANALYTICS_DEBUG=1

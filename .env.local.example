# Copy to .env.local and fill in values.

# Supabase (example — use your project values)
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxx
# Server-only: hosted Checkout + POST /api/stripe/webhook (writes organization_subscriptions). Never expose to the browser.
# SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxx

# Stripe — publishable key (client) and secrets (server). Webhook secret for POST /api/stripe/webhook (signature verification).
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxx
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxx
# BlitzPay / Stripe Connect — separate webhook signing secret for POST /api/blitzpay/webhook (account.updated).
# Do not reuse STRIPE_WEBHOOK_SECRET. See docs/BLITZPAY_PHASE_1.md
# STRIPE_BLITZPAY_WEBHOOK_SECRET=whsec_xxxxxxxxx
# Phase 2 — tenant invoice pay (global kill switch; default off). See docs/BLITZPAY_PHASE_2_ARCHITECTURE.md
# BLITZPAY_INVOICE_PAY_ENABLED=false

# Internal Growth Engine (platform admin only; requires migration + service role)
# GROWTH_ENGINE_ENABLED=false
# GROWTH_ENGINE_AI_ORG_ID=<uuid-of-blitz-internal-org-for-ai-usage-logs>
# Operator-only QA controls on pattern enrollment detail (non-production by default; set true to force-enable in production)
# GROWTH_ENABLE_QA_ACCELERATION=true
# Comma-separated internal test recipient emails for QA deliverability bypass (standalone mode + platform admin only)
# GROWTH_QA_ALLOWED_RECIPIENTS=mike@blitzind.com,qa@example.com
# Platform admin allowlist (comma-separated emails). Alias: PLATFORM_ADMIN_EMAILS
# EQUIPIFY_PLATFORM_ADMIN_EMAILS=you@example.com

# =============================================================================
# Voice / AI Communications — see docs/VOICE_ENVIRONMENT_REQUIREMENTS.md
# Deployment checklists: docs/VOICE_DEPLOYMENT_CHECKLIST.md
# =============================================================================

# --- Voice platform gates (required before any /api/voice/* surface) ---
# Apply voice schema migrations (foundation: 20270527140000) before enabling.

# --- Twilio telephony (Phase 1A inbound webhooks + status/recording callbacks) ---
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# Outbound caller ID for conference/transfer dial-out (alias: TWILIO_PHONE_NUMBER)
# TWILIO_VOICE_FROM_NUMBER=+15551234567

# --- Twilio browser calling / Voice SDK (Phase 1D) ---
# TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_API_KEY_SECRET=your_twilio_api_key_secret
# TWILIO_TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# VOICE_BROWSER_CALLING_PROVIDER=twilio
# Webhook paths (configure in Twilio Console):
#   POST {ORIGIN}/api/voice/inbound/twilio
#   POST {ORIGIN}/api/voice/webhooks/twilio
#   POST {ORIGIN}/api/voice/webhooks/twilio/recording

# --- Media streaming + transcripts (Phase 1F) ---
# Public HTTPS/WSS origin Twilio uses for Media Streams (required behind proxy)
# VOICE_MEDIA_STREAM_PUBLIC_ORIGIN=https://app.equipify.ai
# Allow WebSocket upgrade on /api/voice/media/twilio (or use external WS proxy)
# VOICE_MEDIA_WEBSOCKET_UPGRADE_ENABLED=false
# VOICE_TRANSCRIPT_PROVIDER=stub
# Valid: deepgram | assemblyai | openai_realtime | none | (unset → stub)
# DEEPGRAM_API_KEY=your_deepgram_api_key
# TWILIO_VOICE_INCOMING_STREAM_ENABLED=true
# Local media websocket dev server: pnpm voice:media-websocket-dev
# VOICE_MEDIA_WEBSOCKET_PORT=3001
# ASSEMBLYAI_API_KEY=your_assemblyai_api_key

# --- Voice AI Copilot (Phase 3A — suggestion-only operator assist) ---
# VOICE_AI_COPILOT_PROVIDER=deterministic_template
# VOICE_AI_COPILOT_OPENAI_ENABLED=false
# Live OpenAI requires: VOICE_AI_COPILOT_PROVIDER=openai + OPENAI_API_KEY

# --- Conversation intelligence (passive analysis; default: deterministic rules) ---
# VOICE_INTELLIGENCE_PROVIDER=deterministic_rules
# VOICE_INTELLIGENCE_OPENAI_ENABLED=false

# --- Voice AI Inbound Receptionist (Phase 4A — default: disabled) ---
# VOICE_AI_RECEPTIONIST_ENABLED=false
# VOICE_AI_RECEPTIONIST_PROVIDER=deterministic
# Scaffold providers: deepgram | openai_realtime | openai | elevenlabs | stub

# --- Missed call recovery + voice drops (Phase 4B — default: disabled) ---
# VOICE_MISSED_CALL_RECOVERY_ENABLED=false
# VOICE_DROP_ENABLED=false
# VOICE_DROP_PROVIDER=stub
# Valid: stub | twilio | ringless_future
# Twilio live outbound requires certification after compliance review (VD-1A):
# VOICE_DROP_TWILIO_OUTBOUND_CERTIFIED=false
# Run certification harness before enabling live calls: pnpm test:voice-drop-twilio-vd-1b
# Full sequence + Apollo readiness audit: pnpm test:voice-drop-sequence-vd-4
# Optional — validate captured live certification evidence JSON:
# VOICE_DROP_VD_4_EVIDENCE_JSON=./evidence/vd-4-live.json
# Optional — Supabase probe for a live delivery attempt row:
# VOICE_DROP_VD_4_CERT_ATTEMPT_ID=
# Webhook paths (Twilio uses these automatically via call create):
#   POST {ORIGIN}/api/voice/webhooks/twilio/voice-drop/twiml
#   POST {ORIGIN}/api/voice/webhooks/twilio/voice-drop/status

# --- Compliance orchestration (Phase 4C — default: disabled) ---
# VOICE_COMPLIANCE_ORCHESTRATION_ENABLED=false

# --- Voice AI Outbound (Phase 5A — supervised, approval-gated; default: disabled) ---
# VOICE_AI_OUTBOUND_ENABLED=false
# VOICE_AI_OUTBOUND_PROVIDER=deterministic

# --- Observability + workflow analytics (Phase 5B — enable first in prod rollout) ---
# VOICE_OBSERVABILITY_ENABLED=false

# --- Workflow orchestration intelligence (Phase 5C — default: disabled) ---
# VOICE_WORKFLOW_ORCHESTRATION_ENABLED=false

# --- Unified multi-channel communications intelligence (Phase 6A — default: disabled) ---
# VOICE_MULTICHANNEL_INTELLIGENCE_ENABLED=false

# --- AI provider keys (shared: copilot, intelligence, receptionist/outbound scaffolds, transcripts) ---
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
# ELEVENLABS_API_KEY=your_elevenlabs_api_key

# --- DANGEROUS: dev/local ONLY — NEVER enable in Vercel Production ---
# Skips Twilio webhook signature validation (for ngrok local testing only)
# TWILIO_WEBHOOK_SKIP_SIGNATURE_VALIDATION=false
# VOICE_WEBHOOK_SKIP_SIGNATURE_VALIDATION=false

# GROWTH_RESEARCH_WEBSITE_ENABLED=false
# GROWTH_RESEARCH_WEBSITE_TIMEOUT_MS=8000
# GROWTH_RESEARCH_WEBSITE_MAX_BYTES=1572864
# GROWTH_RESEARCH_WEBSITE_EXCERPT_CHARS=8000
# Per-org enable: set blitzpay_org_settings.blitzpay_invoice_pay_enabled = true (service role / SQL) for the organization UUID.

# BlitzPay Phase 2AA — optional server-only pepper for hashing Stripe object references in DB (migration filename may still say phase_3a; see docs/STRIPE_PRODUCTION_READINESS.md).
# BLITZPAY_STRIPE_REF_PEPPER=
# Phase 3A — internal GL source fingerprint (server-only; optional in dev)
# BLITZPAY_GL_SOURCE_PEPPER=
# BlitzPay Phase 4A — AI financial copilot immutable audit hashing (server-only; optional in dev; do not reuse GL pepper)
# BLITZPAY_AI_AUDIT_PEPPER=
# BlitzPay Phase 4B — revenue optimization audit hashing (server-only; optional in dev; distinct from AI + GL peppers)
# BLITZPAY_REVENUE_OPT_AUDIT_PEPPER=
# BlitzPay Phase 5A — multi-entity audit hashing (server-only; optional in dev; distinct from other BlitzPay peppers)
# BLITZPAY_MULTI_ENTITY_AUDIT_PEPPER=
# BlitzPay Phase 5B — supplier network audit hashing (server-only; optional in dev)
# BLITZPAY_SUPPLIER_NETWORK_AUDIT_PEPPER=
# BLITZPAY_CLAIMS_AUDIT_PEPPER=
# BLITZPAY_MOBILE_AUDIT_PEPPER=
# BLITZPAY_MOBILE_SIGNATURE_PEPPER=
# BLITZPAY_OBSERVABILITY_AUDIT_PEPPER=

# Optional: POST /api/organizations/…/invoices/…/blitzpay/prepare-pay rate buckets (uses ai_operation_rate_buckets). Defaults are conservative if unset.
# BLITZPAY_RATE_PREPARE_PER_ORG_PER_MIN=20
# BLITZPAY_RATE_PREPARE_PER_INVOICE_PER_MIN=8
# BLITZPAY_RATE_PREPARE_PER_USER_PER_MIN=10

# BlitzPay SaaS tier gates (client + shared helpers). Default off — keeps FCC permissive during rollout.
# When true, FCC nav/sections hide catalog-gated modules below their packaging tier (see lib/blitzpay/packaging-surface.ts).
# NEXT_PUBLIC_BLITZPAY_ENFORCE_TIER_GATES=true

# Temporary: sanitized server logs for POST …/blitzpay/enable and account-link (disable after debugging).
# BLITZPAY_ENABLE_DEBUG=true

# Optional: force live key checks without Vercel Production (sk_live_/pk_live_ required).
# See docs/STRIPE_PRODUCTION_READINESS.md
# STRIPE_LIVE_MODE=true

# Public app URL — used for Stripe redirects, invite links, signup welcome, AI Ops digest links.
# Prefer NEXT_PUBLIC_SITE_URL; see docs/EMAIL_INFRASTRUCTURE.md for fallbacks.
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# Server-only fallback (optional): APP_URL=https://staging.example.com

# Stripe Price IDs (Dashboard → Products → each Price).
# Required for checkout validation against real IDs and webhook inverse-mapping.
# Optional in dev if you use catalog placeholders only locally.

# STRIPE_PRICE_SOLO_MONTHLY=price_xxxxxxxxx
# STRIPE_PRICE_SOLO_ANNUAL=price_xxxxxxxxx

# STRIPE_PRICE_CORE_MONTHLY=price_xxxxxxxxx
# STRIPE_PRICE_CORE_ANNUAL=price_xxxxxxxxx

# STRIPE_PRICE_GROWTH_MONTHLY=price_xxxxxxxxx
# STRIPE_PRICE_GROWTH_ANNUAL=price_xxxxxxxxx

# STRIPE_PRICE_SCALE_MONTHLY=price_xxxxxxxxx
# STRIPE_PRICE_SCALE_ANNUAL=price_xxxxxxxxx

# OpenAI — server-only. Used for:
# - AI-assisted certificate template import (PDF/images)
# - Voice AI copilot, intelligence, receptionist/outbound scaffolds, openai_realtime transcript placeholder
# - Growth AI copilot and realtime bridges
# Never commit real keys or expose this variable to the browser.
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx

# Optional model override (defaults to gpt-4o)
# OPENAI_IMPORT_MODEL=gpt-4o

# QuickBooks Online — Intuit Developer App (OAuth 2.0).
# Callback route:
# /api/integrations/quickbooks/callback
# Register the exact REDIRECT_URI in the Intuit app.

# QUICKBOOKS_CLIENT_ID=xxxxxxxxxxxxxxxx
# QUICKBOOKS_CLIENT_SECRET=xxxxxxxxxxxxxxxx
# QUICKBOOKS_REDIRECT_URI=http://localhost:3000/api/integrations/quickbooks/callback

# When set to `1`, AIden **prepared workspace** actions are packaged by plan tier (Solo → Scale matrix).
# Leave unset or `0` to keep legacy permissive `planGate` behavior on definitions.
# AIDEN_PREPARED_WORKSPACE_TIER_GATING=1

# Optional: LLM proposes prepared-workspace intent (strict JSON + merge + resolver validation). When unset/false, parsing stays deterministic-only.
# AIDEN_PREPARED_INTENT_LLM_ENABLED=true

# Optional: defaults to production accounting API. For Intuit sandbox companies, set the sandbox API host
# (URL must include "sandbox" so the app labels the deployment as sandbox in Settings).
# QUICKBOOKS_API_BASE_URL=https://sandbox-quickbooks.api.intuit.com

# HMAC secret for OAuth state (min 16 chars);
# required for /api/integrations/quickbooks/authorize
# INTEGRATION_OAUTH_STATE_SECRET=xxxxxxxxxxxxxxxx

# Resend — transactional email (server only). Used by invoice/quote emails, invites, onboarding welcome (Phase 54.4).
# If unset, provisioning still succeeds but emails are skipped with structured logs.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
# EMAIL_FROM_ADDRESS="Equipify <onboarding@yourdomain.com>"
# Optional reply-to for customer-facing messages (welcome, invoices, etc.)
# EMAIL_REPLY_TO=support@yourdomain.com

# Internal alert when a self-serve workspace finishes POST /api/onboarding/provision (default: mike@equipify.ai)
# EMAIL_SIGNUP_INTERNAL_NOTIFY=mike@equipify.ai

# See docs/SIGNUP_PROVISION_EMAILS.md and docs/EMAIL_INFRASTRUCTURE.md

# --- SMS (workspace transactional; foundation only) ---
# Optional kill-switch for internal callers: when exactly `true`, `queueTransactionalSmsNotification` may attempt provider send after all other gates pass.
# Provider credentials (e.g. Twilio) must never be exposed to the client — see docs/SMS_ARCHITECTURE.md
# EQUIPIFY_SMS_SEND_ENABLED=true

# --- Future: Gmail / Google mailbox OAuth (not wired in app yet; Phase 55.5 is docs + honest UI only) ---
# Register a Google Cloud OAuth 2.0 Web client; never expose client secret to the browser.
# See docs/GMAIL_INTEGRATION.md for boundaries vs Resend.
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_GMAIL_REDIRECT_URI=http://localhost:3000/api/integrations/google-mail/callback
# Optional: GOOGLE_GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.send

# --- Growth Engine Real-World Discovery — Google Places (Prospect Search) ---
# Enable Places API (New) in Google Cloud; Text Search only — no scraping.
# GOOGLE_PLACES_API_KEY=

# --- Growth Engine Real-World Discovery — SerpAPI (Prospect Search) ---
# SerpAPI Google Maps engine — no on-page scraping.
# SERPAPI_API_KEY=
# Optional alias: SERP_API_KEY=

# --- Growth Engine Contact Acquisition — People Data Labs (PDL) ---
# PDL augments internal + website contact discovery — Equipify ranking applies after merge.
# PEOPLE_DATA_LABS_API_KEY=
# Optional alias: PDL_API_KEY=
# GROWTH_CONTACT_DISCOVERY_PDL_ENABLED=true
# GROWTH_PDL_USE_MOCK=true
# PDL_USE_SANDBOX=true
# GROWTH_DISCOVERY_DISABLE_PDL=1
# Live benchmark safety:
# GROWTH_PDL_LIVE_BENCHMARK_ACK=1
# Per-run guardrails (defaults: lookups 40, companies 25, contacts/company 25, daily 500):
# GROWTH_PDL_MAX_LOOKUPS_PER_RUN=40
# GROWTH_PDL_MAX_COMPANIES_PER_RUN=25
# GROWTH_PDL_MAX_CONTACTS_PER_COMPANY=25
# GROWTH_PDL_MAX_DAILY_LOOKUPS=500
# Certification: pnpm test:growth-pdl-production-integration-ge-providers-1a

# --- Apollo contact discovery (Phase 7.PCA-2/3) ---
# People search via mixed_people/api_search (no credits by default).
# Optional email enrichment via people/bulk_match when GROWTH_APOLLO_ENRICH_EMAILS=true (consumes credits).
# APOLLO_API_KEY=
# Optional alias: GROWTH_APOLLO_API_KEY=
# GROWTH_CONTACT_DISCOVERY_APOLLO_ENABLED=true
# GROWTH_APOLLO_USE_MOCK=true
# GROWTH_APOLLO_ENRICH_EMAILS=false
# GROWTH_DISCOVERY_DISABLE_APOLLO=1
# Live benchmark safety (Phase 7.PCA-3):
# GROWTH_APOLLO_LIVE_BENCHMARK_ACK=1
# GROWTH_APOLLO_ENRICH_EMAILS_ACK=1
# Apollo EN-1/EN-2 enrichment cert (one company, max 10 people, consumes credits when live).
# EN-2 (recommended): set on Vercel Production only — POST /api/platform/growth/apollo-enrichment-cert/execute
# GROWTH_APOLLO_EN_1_CERT_ENABLED=true
# GROWTH_APOLLO_EN_1_CERT_ACK=1
# GROWTH_APOLLO_EN_1_COMPANY_CANDIDATE_ID=
# GROWTH_APOLLO_EN_1_MAX_PEOPLE=10
# Tests: pnpm test:apollo-enrichment-cert-production-route
# GROWTH_APOLLO_MAX_COMPANIES_PER_RUN=54
# GROWTH_APOLLO_MAX_API_CALLS_PER_RUN=60
# Scale-3 full 15-company tier A–E cert: recommend 90 (15×5=75 + retry headroom)
# GROWTH_APOLLO_SINGLE_COMPANY_SEARCH_DIAGNOSTIC_ACK=1
# GROWTH_APOLLO_MAX_CONTACTS_PER_COMPANY=25
# APOLLO_BENCHMARK_COMPANY_LIMIT=54
# APOLLO_BENCHMARK_ENRICH_COMPANY_LIMIT=10
# Full AI-1 audit + certification: pnpm test:apollo-integration-ai-1
# AI-2 live pilot (single company, real API — not for CI):
# GROWTH_APOLLO_AI_2_LIVE_PILOT_ENABLED=true
# GROWTH_APOLLO_AI_2_COMPANY_CANDIDATE_ID=
# GROWTH_APOLLO_AI_2_OUTPUT_PATH=./evidence/apollo-ai-2-pilot.json
# APOLLO_AI_2_PILOT_EVIDENCE_JSON=./evidence/apollo-ai-2-pilot.json
# pnpm run:apollo-live-pilot-ai-2
# pnpm test:apollo-integration-ai-2
# AI-3 production rollout certification:
# GROWTH_APOLLO_AI_3_LIVE_PILOT_ENABLED=true
# GROWTH_APOLLO_AI_3_COMPANY_CANDIDATE_ID=
# GROWTH_APOLLO_AI_3_OUTPUT_PATH=./evidence/apollo-ai-3-pilot.json
# APOLLO_AI_3_PILOT_EVIDENCE_JSON=./evidence/apollo-ai-3-pilot.json
# APOLLO_VD4_LIVE_CERTIFIED=true   # after Voice Drop VD-4 live cert
# pnpm run:apollo-live-pilot-ai-3
# pnpm test:apollo-integration-ai-3
# AI-4 live pilot execution prep (env check, company select, dry-run — no new features):
# pnpm check:apollo-live-pilot-env-ai-4:production
# APOLLO_TEST_COMPANY_SEED_ACK=1 APOLLO_TEST_COMPANY_PROFILE=henry_schein pnpm prepare:apollo-live-pilot-test-company:production
# APOLLO_TEST_COMPANY_NAME="Henry Schein" APOLLO_TEST_COMPANY_DOMAIN="henryschein.com" APOLLO_TEST_COMPANY_WEBSITE="https://www.henryschein.com"
# pnpm select:apollo-live-pilot-test-company-ai-4:production
# APOLLO_AI_4_COMPANY_CANDIDATE_ID=   # optional explicit company
# APOLLO_AI_4_COMPANY_NAME_SEARCH=    # optional name filter
# pnpm dry-run:apollo-live-pilot-ai-4
# pnpm test:apollo-integration-ai-4
# AI-5 production activation & first outreach certification (evidence only):
# APOLLO_AI_5_PILOT_EVIDENCE_JSON=./evidence/apollo-ai-3-pilot.json
# pnpm test:apollo-integration-ai-5
# LE-1 final Apollo + Voice Drop production test (evidence only):
# APOLLO_AI_5_PILOT_EVIDENCE_JSON=./evidence/apollo-ai-3-pilot.json
# LE_1_MANUAL_ENROLLMENT_EVIDENCE_JSON=./evidence/le-1-manual-enrollment.json
# LE_1_NON_VOICE_CHANNEL_EVIDENCE_JSON=./evidence/le-1-non-voice-channels.json
# LE_1_VOICE_DROP_EVIDENCE_JSON=./evidence/le-1-voice-drop-live.json
# pnpm test:le-1-apollo-voice-drop-production
# LE-2 / LE-4 Apollo live pilot — configure in Vercel Production (not .env.local):
# vercel env run -e production -- pnpm run:le-2-apollo-live-pilot
# See docs/LE_4_APOLLO_LIVE_PILOT_EXECUTION.md

# Provider query cache (Prompt 30) — apply migration containing growth.provider_query_cache (currently 20270407120000_growth_engine_provider_query_cache.sql)
# Caches Google Places / SERP discovery results server-side (service_role only). TTL: Places 14d, SERP 7d.

# --- Growth Engine Google Calendar OAuth (platform admin; slice 6.27A) ---
# Separate OAuth client from Supabase Auth sign-in. Enable Calendar API in Google Cloud.
# GROWTH_GOOGLE_CALENDAR_CLIENT_ID=
# GROWTH_GOOGLE_CALENDAR_CLIENT_SECRET=
# GROWTH_GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3000/api/platform/growth/calendar/callback
# Optional: GROWTH_GOOGLE_CALENDAR_SCOPES=https://www.googleapis.com/auth/calendar.events https://www.googleapis.com/auth/userinfo.email
# Requires INTEGRATION_OAUTH_STATE_SECRET (shared with QuickBooks OAuth state signing)

# --- Growth Engine Live Provider Setup (Phase 2W; platform admin) ---
# Apply migration 20270428120000_growth_live_provider_setup.sql
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/platform/growth/provider-setup/google/callback
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_TENANT_ID=common
# MICROSOFT_REDIRECT_URI=http://localhost:3000/api/platform/growth/provider-setup/microsoft/callback
# GROWTH_PROVIDER_SECRET_PEPPER= (alias: GROWTH_PROVIDER_CREDENTIALS_PEPPER)
# Production build fails if dev fallback pepper is used — see scripts/verify-growth-production-runtime.ts
# GROWTH_TRACKING_BASE_URL=https://track.your-domain.com
# Optional dev only (NEVER in Vercel Production — build fails):
# GROWTH_TRANSPORT_SIMULATE=true
# GROWTH_INBOX_SYNC_SIMULATE=true
